page {
  background-color: #fef9f3;
}

.container {
  padding: 0 24rpx 40rpx;
  min-height: calc(100vh - 88px);
}

.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 60rpx;
}

.header-dog {
  width: 200rpx;
  height: 200rpx;
  animation: headerDogBounce 2s ease-in-out infinite;
}

@keyframes headerDogBounce {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  25% {
    transform: translateY(-10rpx) rotate(-5deg);
  }
  75% {
    transform: translateY(-10rpx) rotate(5deg);
  }
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #6b5637;
  margin-top: 20rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: #a0845e;
  margin-top: 12rpx;
}

.daily-mood {
  background-color: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  border: 4rpx dashed #f0e0d0;
  box-shadow: 0 8rpx 24rpx rgba(139, 111, 71, 0.1);
}

.mood-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.mood-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.mood-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #6b5637;
}

.mood-content {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.mood-dog {
  width: 160rpx;
  height: 160rpx;
  margin-right: 32rpx;
  animation: moodDogWave 3s ease-in-out infinite;
}

@keyframes moodDogWave {
  0%, 100% {
    transform: rotate(0deg);
  }
  25% {
    transform: rotate(-10deg);
  }
  75% {
    transform: rotate(10deg);
  }
}

.mood-text {
  font-size: 30rpx;
  color: #8b6f47;
  line-height: 1.6;
}

.mood-paws {
  text-align: center;
  font-size: 28rpx;
  opacity: 0.4;
  letter-spacing: 20rpx;
  margin-top: 20rpx;
}

.dog-quote {
  background: linear-gradient(135deg, #fff5eb 0%, #fef9f3 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  border: 2rpx dashed #f0e0d0;
  position: relative;
}

.quote-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.quote-text {
  font-size: 30rpx;
  color: #6b5637;
  line-height: 1.8;
  font-style: italic;
}

.quote-author {
  font-size: 24rpx;
  color: #a0845e;
  text-align: right;
  margin-top: 16rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin: 40rpx 0 24rpx;
}

.title-paw {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #6b5637;
}

.diary-scroll {
  height: 600rpx;
}

.diary-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx dashed #f0e0d0;
  box-shadow: 0 4rpx 16rpx rgba(139, 111, 71, 0.08);
}

.diary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx dashed #f5e6d8;
}

.diary-dog {
  width: 80rpx;
  height: 80rpx;
}

.diary-date {
  font-size: 24rpx;
  color: #a0845e;
}

.diary-content {
  font-size: 28rpx;
  color: #6b5637;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.diary-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.diary-paws {
  font-size: 24rpx;
  opacity: 0.4;
  letter-spacing: 8rpx;
}

.diary-like {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background-color: #fef9f3;
  border-radius: 20rpx;
  border: 2rpx solid #f0e0d0;
}

.like-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.like-count {
  font-size: 24rpx;
  color: #8b6f47;
}

.facts-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.fact-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 2rpx dashed #f0e0d0;
  box-shadow: 0 4rpx 16rpx rgba(139, 111, 71, 0.08);
  transition: transform 0.2s;
}

.fact-card:active {
  transform: scale(0.95);
}

.fact-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.fact-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #6b5637;
  margin-bottom: 8rpx;
}

.fact-preview {
  font-size: 24rpx;
  color: #a0845e;
  line-height: 1.5;
}

.dog-stamp {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.stamp-dog {
  width: 160rpx;
  height: 160rpx;
  animation: stampRotate 4s ease-in-out infinite;
}

@keyframes stampRotate {
  0%, 100% {
    transform: rotate(0deg) scale(1);
  }
  50% {
    transform: rotate(10deg) scale(1.1);
  }
}

.stamp-text {
  font-size: 24rpx;
  color: #a0845e;
  margin-top: 12rpx;
  letter-spacing: 4rpx;
}
