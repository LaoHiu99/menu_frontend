page {
  background-color: #fef9f3;
}

.container {
  padding: 0 24rpx 40rpx;
  min-height: calc(100vh - 88px);
}

.profile-section {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fff5eb 0%, #fef9f3 100%);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  border: 4rpx dashed #f0e0d0;
  box-shadow: 0 8rpx 24rpx rgba(139, 111, 71, 0.1);
}

.profile-dog {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #f5e6d8;
  margin-right: 24rpx;
  animation: profileDogWave 3s ease-in-out infinite;
}

.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  margin-right: 24rpx;
}

.avatar-btn::after {
  border: none;
}

.avatar-btn:active {
  opacity: 0.7;
}

@keyframes profileDogWave {
  0%,
  100% {
    transform: rotate(0deg);
  }
  25% {
    transform: rotate(-10deg);
  }
  75% {
    transform: rotate(10deg);
  }
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #6b5637;
  margin-bottom: 8rpx;
}

.profile-signature {
  font-size: 24rpx;
  color: #a0845e;
  line-height: 1.4;
}

.profile-id {
  font-size: 24rpx;
  color: #a0845e;
}

.profile-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 12rpx 20rpx;
  border: 2rpx dashed #f0e0d0;
}

.badge-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #8b6f47;
}

.stats-section {
  background: linear-gradient(135deg, #6b5637 0%, #a0845e 100%);
  border-radius: 32rpx;
  padding: 40rpx 0;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(107, 86, 55, 0.25);
  position: relative;
  overflow: hidden;
}

.stats-section::before {
  content: "";
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.stat-item:not(:last-child)::after {
  content: "";
  position: absolute;
  right: 0;
  top: 20%;
  height: 60%;
  width: 2rpx;
  background: rgba(255, 255, 255, 0.2);
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

.menu-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  border: 2rpx dashed #f0e0d0;
  box-shadow: 0 4rpx 16rpx rgba(139, 111, 71, 0.08);
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.title-paw {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #6b5637;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  transition: transform 0.2s;
}

.menu-item:active {
  transform: scale(0.9);
  background-color: #fef9f3;
}

.menu-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.menu-name {
  font-size: 24rpx;
  color: #6b5637;
}

.dog-quote-section {
  background: linear-gradient(135deg, #fff5eb 0%, #fef9f3 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  border: 2rpx dashed #f0e0d0;
  display: flex;
  align-items: center;
}

.quote-dog {
  width: 120rpx;
  height: 120rpx;
  margin-right: 24rpx;
  animation: quoteDogBounce 2s ease-in-out infinite;
}

@keyframes quoteDogBounce {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.quote-text {
  font-size: 28rpx;
  color: #6b5637;
  line-height: 1.6;
  font-style: italic;
}

.logout-btn {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
  border: 2rpx dashed #e8a598;
  text-align: center;
}

.logout-btn:active {
  background-color: #fef5f3;
}

.logout-text {
  font-size: 30rpx;
  color: #c47a6e;
  font-weight: 500;
}

.footer-paws {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}

.footer-paw {
  font-size: 28rpx;
  opacity: 0.4;
  margin: 0 16rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #a0845e;
  letter-spacing: 2rpx;
}
