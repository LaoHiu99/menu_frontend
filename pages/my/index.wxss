page {
  background-color: #fef9f3;
}

.container {
  padding: 0 24rpx 40rpx;
  min-height: calc(100vh - 88px);
}

.profile-section {
  display: flex;
  align-items: center;
  justify-content: center; /* 添加这一行，实现水平居中 */
  background: linear-gradient(135deg, #fff5eb 0%, #fef9f3 100%);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  border: 4rpx dashed #f0e0d0;
  box-shadow: 0 8rpx 24rpx rgba(139, 111, 71, 0.1);
}

.profile-info {
  flex: 1;
  /* 移除 min-width: 0; 避免内容被压缩 */
  min-width: auto; 
}

.profile-dog {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #f5e6d8;
  margin-right: 24rpx;
  flex-shrink: 0;
  display: block;
  box-sizing: border-box;
  animation: profileDogWave 3s ease-in-out infinite;
}

.avatar-btn {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-sizing: border-box;
  border-radius: 50%;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  margin-right: 24rpx;
}

.avatar-btn::after {
  border: none;
}

.avatar-btn .profile-dog {
  margin-right: 0;
}

.avatar-btn:active {
  opacity: 0.7;
}

.login-hint {
  font-size: 22rpx;
  color: #a0845e;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.wx-login-submit-btn {
  width: 90%;
  max-width: 100%;   /* 确保不超出父容器 */
  box-sizing: border-box;
  font-size: 28rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #e8c9a8 0%, #d4a574 100%);
  color: #fff;
  border-radius: 999rpx;
  border: none;
  font-weight: bold;
}

.wx-login-submit-btn::after {
  border: none;
}

@keyframes profileDogWave {
  0%,
  100% {
    transform: rotate(0deg);
  }
  25% {
    transform: rotate(-10deg);
  }
  75% {
    transform: rotate(10deg);
  }
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #6b5637;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-signature {
  font-size: 24rpx;
  color: #a0845e;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-userid {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 8rpx 16rpx;
  background-color: #fef9f3;
  border-radius: 16rpx;
  border: 2rpx dashed #f0e0d0;
  width: fit-content;
}

.userid-label {
  font-size: 22rpx;
  color: #8b6f47;
  font-weight: 500;
  margin-right: 8rpx;
}

.userid-text {
  font-size: 22rpx;
  color: #a0845e;
  font-family: monospace;
}

.userid-copy-icon {
  font-size: 24rpx;
  margin-left: 12rpx;
  opacity: 0.6;
}

.profile-id {
  font-size: 24rpx;
  color: #a0845e;
}

.profile-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 12rpx 20rpx;
  border: 2rpx dashed #f0e0d0;
}

.badge-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #8b6f47;
}

.stats-section {
  background: linear-gradient(135deg, #6b5637 0%, #a0845e 100%);
  border-radius: 32rpx;
  padding: 40rpx 0;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(107, 86, 55, 0.25);
  position: relative;
  overflow: hidden;
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stats-section::before {
  content: "";
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.stat-item:not(:last-child)::after {
  content: "";
  position: absolute;
  right: 0;
  top: 20%;
  height: 60%;
  width: 2rpx;
  background: rgba(255, 255, 255, 0.2);
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

.friend-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  border: 2rpx dashed #f0e0d0;
  box-shadow: 0 4rpx 16rpx rgba(139, 111, 71, 0.08);
}

.friend-stats {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.friend-stat-item {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 24rpx 16rpx;
  background: linear-gradient(135deg, #fff5eb 0%, #fef9f3 100%);
  border-radius: 20rpx;
  border: 2rpx dashed #f0e0d0;
  position: relative;
  transition: transform 0.2s;
}

.friend-stat-item:active {
  transform: scale(0.95);
}

.friend-stat-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.friend-stat-info {
  display: flex;
  flex-direction: column;
}

.friend-stat-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #6b5637;
  margin-bottom: 4rpx;
}

.friend-stat-label {
  font-size: 22rpx;
  color: #a0845e;
}

.friend-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  background-color: #e85c3d;
  color: #fff;
  font-size: 20rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-shadow: 0 4rpx 8rpx rgba(232, 92, 61, 0.3);
}

.add-friend-btn {
  background: linear-gradient(135deg, #f3ca7e 0%, #e8b86d 100%);
  border-color: #e8b86d;
}

.add-friend-btn .friend-stat-label {
  color: #fff;
  font-weight: 500;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 80%;
  max-width: 100%;
  box-sizing: border-box;
  background-color: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(139, 111, 71, 0.2);
  border: 4rpx dashed #f0e0d0;
  overflow: hidden;
}

.modal-large {
  width: 85%;
  max-width: 100%;
  box-sizing: border-box;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-friends-sheet {
  width: 90%;
  max-width: 90%;
}

/* 好友请求：整弹窗限高，仅列表区域滚动，标题与关闭固定在顶部 */
.modal-friend-requests-wrap {
  display: flex;
  flex-direction: column;
  max-height: 80vh;
  overflow: hidden;
}

.modal-friend-requests-scroll {
  width: 100%;
  box-sizing: border-box;
  /* 留出标题、内边距；列表超出在此区域内滚动 */
  height: calc(80vh - 200px);
  max-height: calc(80vh - 200px);
}

.modal-friend-requests-inner {
  margin-bottom: 0;
  min-width: 0;
  padding-bottom: 24rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx dashed #f0e0d0;
}

.modal-header.modal-friend-requests-header {
  flex-shrink: 0;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #6b5637;
}

.modal-close {
  font-size: 40rpx;
  color: #a0845e;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #fef9f3;
}

.modal-body {
  margin-bottom: 32rpx;
  min-width: 0;
}

.modal-body.modal-friend-requests-inner {
  margin-bottom: 0;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.modal-btn-cancel {
  background-color: #fef9f3;
  color: #a0845e;
  border: 2rpx solid #f0e0d0;
}

.modal-btn-confirm {
  background-color: #f3ca7e;
  color: #fff;
  border: 2rpx solid #e8b86d;
}

.input-group {
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
  min-width: 0;
}

.input-label {
  font-size: 28rpx;
  color: #6b5637;
  font-weight: 500;
  margin-bottom: 16rpx;
  display: block;
}

.friend-id-input {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  min-height: 96rpx;
  padding: 28rpx 24rpx;
  line-height: 1.45;
  background-color: #fef9f3;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #6b5637;
  border: 2rpx dashed #f0e0d0;
}

.empty-requests,
.empty-friends {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #a0845e;
}

.friend-request-item {
  display: flex;
  flex-direction: column;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(145deg, #fffefd 0%, #fef9f3 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(240, 224, 208, 0.9);
  box-shadow: 0 4rpx 16rpx rgba(139, 111, 71, 0.06);
}

.request-card-top {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.request-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
  border: 3rpx solid #f5e6d8;
}

.request-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.request-nickname {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.request-userid {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
  font-family: monospace;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.request-time {
  font-size: 22rpx;
  color: #a0845e;
}

.request-actions-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.request-action-btn {
  flex: 1;
  padding: 22rpx 16rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  box-sizing: border-box;
}

.request-action-btn:active {
  opacity: 0.85;
}

.request-action-btn.reject-outline {
  background-color: #fff;
  color: #a0845e;
  border: 2rpx solid #e8d8c8;
}

.request-action-btn.accept-primary {
  background: linear-gradient(135deg, #f3ca7e 0%, #e8b86d 100%);
  color: #fff;
  border: 2rpx solid #e8b86d;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  text-align: center;
}

.accept-btn {
  background-color: #f3ca7e;
  color: #fff;
  border: 2rpx solid #e8b86d;
}

.reject-btn {
  background-color: #fef9f3;
  color: #a0845e;
  border: 2rpx solid #f0e0d0;
}

.friend-list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background-color: #fef9f3;
  border-radius: 16rpx;
  border: 2rpx dashed #f0e0d0;
}

.friend-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.friend-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.friend-nickname {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.friend-userid {
  font-size: 24rpx;
  color: #999;
}

.delete-friend-btn {
  background-color: #fef5f3;
  color: #c47a6e;
  border: 2rpx solid #e8a598;
}

.menu-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  border: 2rpx dashed #f0e0d0;
  box-shadow: 0 4rpx 16rpx rgba(139, 111, 71, 0.08);
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.title-paw {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #6b5637;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  transition: transform 0.2s;
}

.menu-item:active {
  transform: scale(0.9);
  background-color: #fef9f3;
}

.menu-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.menu-name {
  font-size: 24rpx;
  color: #6b5637;
}

.dog-quote-section {
  background: linear-gradient(135deg, #fff5eb 0%, #fef9f3 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  border: 2rpx dashed #f0e0d0;
  display: flex;
  align-items: center;
}

.quote-dog {
  width: 120rpx;
  height: 120rpx;
  margin-right: 24rpx;
  animation: quoteDogBounce 2s ease-in-out infinite;
}

@keyframes quoteDogBounce {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.quote-text {
  font-size: 28rpx;
  color: #6b5637;
  line-height: 1.6;
  font-style: italic;
}

.logout-btn {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
  border: 2rpx dashed #e8a598;
  text-align: center;
}

.logout-btn:active {
  background-color: #fef5f3;
}

.logout-text {
  font-size: 30rpx;
  color: #c47a6e;
  font-weight: 500;
}

.footer-paws {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}

.footer-paw {
  font-size: 28rpx;
  opacity: 0.4;
  margin: 0 16rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #a0845e;
  letter-spacing: 2rpx;
}
