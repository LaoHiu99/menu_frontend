<!-- 与全局 custom 导航对齐：占位 + 页面内头部 -->
<view class="nav-placeholder" style="height: {{navBarHeight}}px;"></view>
<view class="container">
  <view class="confirm-header">
    <view class="back-btn" bindtap="onGoBack">
      <text class="back-arrow">←</text>
    </view>
    <view class="header-title">下单</view>
  </view>

  <view class="confirm-card">
    <view class="section-title">已选商品</view>
    <view class="goods-list">
      <view class="goods-item" wx:for="{{cartList}}" wx:key="id">
        <image class="goods-image" src="{{item.image}}" mode="aspectFill" />
        <view class="goods-info">
          <view class="goods-name">{{item.name}}</view>
          <view class="goods-detail">
            <view class="goods-count">x{{item.count}}</view>
            <view class="goods-price">¥{{item.price}}</view>
          </view>
        </view>
        <view class="goods-subtotal">
          <view class="subtotal-label">小计</view>
          <view class="subtotal-amount">¥{{item.subtotal}}</view>
        </view>
      </view>
    </view>
    <view class="total-section">
      <view class="total-label">合计</view>
      <view class="total-amount">¥{{totalAmount}}</view>
    </view>
  </view>

  <view class="confirm-card remark-card">
    <view class="remark-head">
      <view class="section-title remark-section-title">备注</view>
      <view class="remark-count">{{remark.length}}/200</view>
    </view>
    <textarea
      class="remark-input"
      placeholder="口味偏好、忌口等（选填）～"
      placeholder-class="remark-placeholder"
      value="{{remark}}"
      maxlength="200"
      bindinput="onRemarkInput"
      auto-height
    />
  </view>

  <view class="page-bottom-spacer"></view>
</view>

<view class="bottom-bar">
  <view class="submit-btn" bindtap="onSubmitOrder">提交订单</view>
</view>
