/* pages/order-confirm/index.wxss — 线条小狗风格，与订单页/个人信息一致 */

page {
  background-color: #fef9f3;
}

.nav-placeholder {
  width: 100%;
  background: linear-gradient(135deg, #fff5eb 0%, #fef9f3 100%);
}

.container {
  padding: 0 24rpx 0;
  box-sizing: border-box;
}

.confirm-header {
  background: linear-gradient(135deg, #fff5eb 0%, #fef9f3 100%);
  border-radius: 32rpx;
  padding: 32rpx 40rpx;
  margin-bottom: 32rpx;
  border: 4rpx dashed #f0e0d0;
  box-shadow: 0 8rpx 24rpx rgba(139, 111, 71, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.confirm-header::after {
  content: "🐾";
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  opacity: 0.5;
}

.back-btn {
  position: absolute;
  left: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.85);
  border: 2rpx dashed #f0e0d0;
}

.back-btn:active {
  opacity: 0.85;
  transform: translateY(-50%) scale(0.96);
}

.back-arrow {
  font-size: 36rpx;
  color: #6b5637;
  font-weight: bold;
  line-height: 1;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #6b5637;
  letter-spacing: 4rpx;
}

.confirm-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx dashed #f0e0d0;
  box-shadow: 0 4rpx 16rpx rgba(139, 111, 71, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #6b5637;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: "🐾";
  margin-right: 12rpx;
  font-size: 28rpx;
}

.remark-section-title {
  margin-bottom: 0;
}

.remark-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.remark-head .remark-count {
  font-size: 24rpx;
  color: #a0845e;
}

.goods-list {
  display: flex;
  flex-direction: column;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #fff5eb 0%, #fef9f3 100%);
  border-radius: 16rpx;
  border: 2rpx dashed #f0e0d0;
}

.goods-list .goods-item:last-child {
  margin-bottom: 0;
}

.goods-image {
  width: 112rpx;
  height: 112rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  border: 2rpx solid #f5e6d8;
}

.goods-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
}

.goods-name {
  font-size: 28rpx;
  color: #6b5637;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-detail {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.goods-count {
  font-size: 24rpx;
  color: #a0845e;
  background-color: rgba(255, 255, 255, 0.9);
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #f0e0d0;
}

.goods-price {
  font-size: 28rpx;
  color: #8b6f47;
  font-weight: 500;
}

.goods-subtotal {
  flex-shrink: 0;
  text-align: right;
  margin-left: 16rpx;
  padding-left: 12rpx;
  border-left: 2rpx dashed #f0e0d0;
}

.subtotal-label {
  font-size: 22rpx;
  color: #a0845e;
}

.subtotal-amount {
  font-size: 26rpx;
  color: #8b6f47;
  font-weight: 600;
  margin-top: 4rpx;
}

.total-section {
  display: flex;
  justify-content: flex-end;
  align-items: baseline;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed #f0e0d0;
}

.total-label {
  font-size: 28rpx;
  color: #6b5637;
  margin-right: 16rpx;
}

.total-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: #c97e3a;
  letter-spacing: 1rpx;
}

.remark-card .section-title {
  margin-bottom: 0;
}

.remark-input {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx;
  box-sizing: border-box;
  background-color: #fef9f3;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #6b5637;
  line-height: 1.5;
  border: 2rpx dashed #f0e0d0;
}

.remark-placeholder {
  color: #c4b09a;
}

.page-bottom-spacer {
  height: 200rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 24rpx 40rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(254, 249, 243, 0.92) 0%, #fef9f3 40%);
  backdrop-filter: blur(8px);
  border-top: 4rpx dashed #f0e0d0;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  background: linear-gradient(135deg, #f3ca7e 0%, #e8b86d 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #e8b86d;
  box-shadow: 0 8rpx 20rpx rgba(243, 202, 126, 0.35);
  letter-spacing: 6rpx;
}

.submit-btn:active {
  opacity: 0.92;
  transform: scale(0.99);
}
