<!-- 自定义导航栏占位 -->
<view class="nav-placeholder" style="height: {{navBarHeight}}px;"></view>

<view class="container">
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" bindtap="onTabChange" data-tab="0">
      <text>未完成</text>
      <view class="tab-badge" wx:if="{{unfinishedCount > 0}}">{{unfinishedCount}}</view>
    </view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" bindtap="onTabChange" data-tab="1">
      <text>已完成</text>
    </view>
  </view>

  <view class="order-list">
    <view wx:if="{{currentOrders.length === 0}}" class="empty-state">
      <image class="empty-icon" src="/images/icons/search.png" mode="aspectFit" />
      <view class="empty-text">暂无订单</view>
    </view>

    <view wx:for="{{currentOrders}}" wx:key="id" class="order-card">
      <view class="order-header">
        <image class="order-avatar" src="{{item.avatar}}" mode="aspectFill" />
        <view class="order-user-info">
          <view class="order-username">{{item.username}}</view>
          <view class="order-time">{{item.time}}</view>
        </view>
        <view class="order-status {{item.status === '已完成' ? 'completed' : 'unfinished'}}">
          {{item.status}}
        </view>
      </view>

      <view class="order-goods">
        <view class="order-goods-item" wx:for="{{item.goods}}" wx:for-item="good" wx:key="index">
          <image class="order-goods-image" src="{{good.image}}" mode="aspectFill" />
          <view class="order-goods-info">
            <view class="order-goods-name">{{good.name}}</view>
            <view class="order-goods-count">x{{good.count}}</view>
          </view>
        </view>
      </view>

      <view wx:if="{{item.remark}}" class="order-remark">
        <text class="remark-label">备注：</text>
        <text class="remark-text">{{item.remark}}</text>
      </view>

      <view class="order-actions" wx:if="{{item.status === '未完成'}}">
        <view class="action-btn cancel-btn" bindtap="onCancelOrder" data-id="{{item.id}}">
          <text>取消订单</text>
        </view>
        <view class="action-btn complete-btn" bindtap="onCompleteOrder" data-id="{{item.id}}">
          <text>完成订单</text>
        </view>
        <view class="action-btn delete-btn" bindtap="onDeleteOrder" data-id="{{item.id}}">
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>
</view>